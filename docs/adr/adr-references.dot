  // Legend
  subgraph "cluster_legend" {
    label="Tier (border color)";
    style="rounded";
    color="#cbd5e1";
    fontsize=10;
    "legend_S" [label="Tier S", color="#b91c1c", penwidth=2, fillcolor="white"];
    "legend_A" [label="Tier A", color="#c2410c", penwidth=2, fillcolor="white"];
    "legend_B" [label="Tier B", color="#a16207", penwidth=2, fillcolor="white"];
    "legend_C" [label="Tier C", color="#15803d", penwidth=2, fillcolor="white"];
    "legend_D" [label="Tier D", color="#1d4ed8", penwidth=2, fillcolor="white"];
    "legend_S" -> "legend_A" [style=invis];
    "legend_A" -> "legend_B" [style=invis];
    "legend_B" -> "legend_C" [style=invis];
    "legend_C" -> "legend_D" [style=invis];
  }
}
