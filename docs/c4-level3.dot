// cherry-pit · C4 Level 3 — Component Diagram
// Render: dot -Tsvg docs/c4-level3.dot -o docs/c4-level3.svg
//
// Color key:
//   Green  (#c8e6c9 fill, #388e3c border) — implemented
//   Amber  (#fff9c4 fill, #f9a825 border) — partially implemented
//   Gray   (#eeeeee fill, #999999 dashed) — planned / stub
//   Blue   (#bbdefb fill, #1565c0 border) — external system
//
// Grouping: pit-core's 17 public exports are grouped into 4 logical
// clusters (Domain Model, Infrastructure Ports, Reactive, Types &
// Errors). Each trait is its own node; error/result type aliases
// share a single node for readability.

digraph cherry_pit_c4_level3 {
    rankdir=TB;
    fontname="Helvetica";
    fontsize=14;
    label="cherry-pit · C4 Level 3 — Component Diagram\n(green = implemented, amber = partial, gray dashed = planned)";
    labelloc=t;
    compound=true;
    nodesep=0.6;
    ranksep=1.0;
    node [fontname="Helvetica", fontsize=10, shape=component, style=filled];
    edge [fontname="Helvetica", fontsize=8];

    // ── Legend ───────────────────────────────────────────────────
    subgraph cluster_legend {
        label="Legend";
        style=rounded;
        color="#999999";
        fontsize=10;
        leg_impl     [label="Implemented",    fillcolor="#c8e6c9", color="#388e3c", shape=box, fontsize=9];
        leg_partial  [label="Partial",        fillcolor="#fff9c4", color="#f9a825", shape=box, fontsize=9];
        leg_planned  [label="Planned / Stub", fillcolor="#eeeeee", color="#999999", style="filled,dashed", shape=box, fontsize=9];
        leg_external [label="External System",fillcolor="#bbdefb", color="#1565c0", shape=box, fontsize=9];
        leg_ext_plan [label="Planned External",fillcolor="#bbdefb", color="#1565c0", style="filled,dashed", shape=box, fontsize=9];
        // Edge styles
        leg_e1 [label="", shape=point, width=0];
        leg_e2 [label="", shape=point, width=0];
        leg_e3 [label="", shape=point, width=0];
        leg_e4 [label="", shape=point, width=0];
        leg_e1 -> leg_e2 [label="implemented", style=bold, color="#388e3c"];
        leg_e3 -> leg_e4 [label="planned",     style=dashed, color="#999999"];
    }

    // ── External Systems ─────────────────────────────────────────
    ext_fs   [label="Local Filesystem\n(.msgpack files)",        shape=cylinder, fillcolor="#bbdefb", color="#1565c0"];
    ext_nats [label="NATS / JetStream\n(event transport)",       shape=cylinder, fillcolor="#bbdefb", color="#1565c0", style="filled,dashed"];

    // ── pit-core ─────────────────────────────────────────────────
    // Status: COMPLETE (17 public exports, all implemented)
    subgraph cluster_pit_core {
        label="pit-core\n[Rust crate — foundational traits]";
        style="filled,rounded";
        fillcolor="#e8f5e9";
        color="#388e3c";
        fontcolor="#1b5e20";

        subgraph cluster_domain_model {
            label="Domain Model";
            style=rounded;
            color="#66bb6a";
            fillcolor="#f1f8e9";

            domain_event    [label="«trait» DomainEvent\nSerialize + DeserializeOwned\nevent_type() discriminator",
                             fillcolor="#c8e6c9", color="#388e3c"];
            command         [label="«trait» Command\nSend + Sync marker",
                             fillcolor="#c8e6c9", color="#388e3c"];
            aggregate       [label="«trait» Aggregate\nDefault + apply(event)\ntype Event: DomainEvent",
                             fillcolor="#c8e6c9", color="#388e3c"];
            handle_command  [label="«trait» HandleCommand<C>\nhandle(cmd) → Vec<Event>\ntype Error",
                             fillcolor="#c8e6c9", color="#388e3c"];
        }

        subgraph cluster_ports {
            label="Infrastructure Ports (async RPITIT)";
            style=rounded;
            color="#66bb6a";
            fillcolor="#f1f8e9";

            event_store_trait [label="«trait» EventStore\nload / create / append\ntype Event",
                               fillcolor="#c8e6c9", color="#388e3c"];
            event_bus_trait   [label="«trait» EventBus\npublish(envelopes)\ntype Event",
                               fillcolor="#c8e6c9", color="#388e3c"];
            command_bus_trait [label="«trait» CommandBus\ncreate / dispatch\ntype Aggregate",
                               fillcolor="#c8e6c9", color="#388e3c"];
            command_gw_trait  [label="«trait» CommandGateway\ncreate / send\ntype Aggregate",
                               fillcolor="#c8e6c9", color="#388e3c"];
        }

        subgraph cluster_reactive {
            label="Reactive";
            style=rounded;
            color="#66bb6a";
            fillcolor="#f1f8e9";

            policy     [label="«trait» Policy\nreact(envelope) → Vec<Output>\ntype Event, type Output",
                        fillcolor="#c8e6c9", color="#388e3c"];
            projection [label="«trait» Projection\napply(envelope)\ntype Event",
                        fillcolor="#c8e6c9", color="#388e3c"];
        }

        subgraph cluster_types {
            label="Types & Errors";
            style=rounded;
            color="#66bb6a";
            fillcolor="#f1f8e9";

            event_envelope [label="«struct» EventEnvelope<E>\nevent_id: UUID v7\naggregate_id, sequence\ntimestamp: jiff::Timestamp",
                            fillcolor="#c8e6c9", color="#388e3c"];
            aggregate_id   [label="«newtype» AggregateId(u64)\nCopy, Serialize, Display",
                            fillcolor="#c8e6c9", color="#388e3c"];
            errors         [label="DispatchError<E>\nStoreError\nBusError\nDispatchResult\nCreateResult",
                            fillcolor="#c8e6c9", color="#388e3c"];
        }
    }

    // ── pit-gateway ──────────────────────────────────────────────
    // Status: PARTIAL — MsgpackFileStore implemented; 3 impls planned
    subgraph cluster_pit_gateway {
        label="pit-gateway\n[Rust crate — port implementations]";
        style="filled,rounded";
        fillcolor="#fffde7";
        color="#f9a825";
        fontcolor="#e65100";

        msgpack_store    [label="MsgpackFileStore<E>\nimpl EventStore\nMessagePack serialization\natomic writes (temp+rename)\nper-aggregate write locks\n20 tests",
                          fillcolor="#c8e6c9", color="#388e3c"];
        command_bus_impl [label="CommandBus impl\n(load → handle → persist → publish)",
                          fillcolor="#eeeeee", color="#999999", style="filled,dashed"];
        event_bus_impl   [label="EventBus impl\n(in-process fan-out)",
                          fillcolor="#eeeeee", color="#999999", style="filled,dashed"];
        command_gw_impl  [label="CommandGateway impl\n(retry, interceptors, middleware)",
                          fillcolor="#eeeeee", color="#999999", style="filled,dashed"];
    }

    // ── pardosa-genome ───────────────────────────────────────────
    // Status: PLANNED — no source on disk
    subgraph cluster_pardosa_genome {
        label="pardosa-genome\n[Rust crate — append-only file format]";
        style="filled,rounded,dashed";
        fillcolor="#fafafa";
        color="#999999";
        fontcolor="#616161";

        pg_log       [label="Log\nappend-only structure",  fillcolor="#eeeeee", color="#999999", style="filled,dashed"];
        pg_entry     [label="Entry\nlog entry format",     fillcolor="#eeeeee", color="#999999", style="filled,dashed"];
        pg_version   [label="Version\nlog versioning",     fillcolor="#eeeeee", color="#999999", style="filled,dashed"];
        pg_migration [label="Migration\nmigration engine",  fillcolor="#eeeeee", color="#999999", style="filled,dashed"];
        pg_integrity [label="Integrity\nSHA-256 hashing",  fillcolor="#eeeeee", color="#999999", style="filled,dashed"];
    }

    // ── pardosa-genome-derive ────────────────────────────────────
    // Status: PLANNED — no source on disk
    subgraph cluster_pardosa_derive {
        label="pardosa-genome-derive\n[proc-macro crate]";
        style="filled,rounded,dashed";
        fillcolor="#fafafa";
        color="#999999";
        fontcolor="#616161";

        pgd_macros [label="Derive Macros\nsyn + quote codegen", fillcolor="#eeeeee", color="#999999", style="filled,dashed"];
    }

    // ── pardosa ──────────────────────────────────────────────────
    // Status: PLANNED — no source on disk
    subgraph cluster_pardosa {
        label="pardosa\n[Rust crate — serialization & transport]";
        style="filled,rounded,dashed";
        fillcolor="#fafafa";
        color="#999999";
        fontcolor="#616161";

        p_serializer [label="Serializer\nserde integration\nschema evolution",          fillcolor="#eeeeee", color="#999999", style="filled,dashed"];
        p_transport  [label="NATS Transport\nJetStream publish / consume\ncross-context events", fillcolor="#eeeeee", color="#999999", style="filled,dashed"];
        p_pruning    [label="Data Pruning\nGDPR-compliant\nmigration-time ops",         fillcolor="#eeeeee", color="#999999", style="filled,dashed"];
    }

    // ── pit-web ──────────────────────────────────────────────────
    // Status: PLANNED — no source on disk
    subgraph cluster_pit_web {
        label="pit-web\n[Rust crate — HTTP adapter]";
        style="filled,rounded,dashed";
        fillcolor="#fafafa";
        color="#999999";
        fontcolor="#616161";

        pw_http       [label="HTTP Endpoints\naxum router\nwebhooks, REST API",   fillcolor="#eeeeee", color="#999999", style="filled,dashed"];
        pw_ws         [label="WebSocket\nreal-time event push",                    fillcolor="#eeeeee", color="#999999", style="filled,dashed"];
        pw_middleware [label="Middleware\ntower-http\nrate limiting, tracing",      fillcolor="#eeeeee", color="#999999", style="filled,dashed"];
    }

    // ── pit-projection ───────────────────────────────────────────
    // Status: PLANNED — no source on disk
    subgraph cluster_pit_projection {
        label="pit-projection\n[Rust crate — read models]";
        style="filled,rounded,dashed";
        fillcolor="#fafafa";
        color="#999999";
        fontcolor="#616161";

        pp_store [label="Read Model Store\nin-memory → SQLite / PG", fillcolor="#eeeeee", color="#999999", style="filled,dashed"];
        pp_query [label="Query Serving\nread-side API",              fillcolor="#eeeeee", color="#999999", style="filled,dashed"];
    }

    // ── pit-agent ────────────────────────────────────────────────
    // Status: PLANNED — no source on disk
    subgraph cluster_pit_agent {
        label="pit-agent\n[Rust crate — agent composition surface]";
        style="filled,rounded,dashed";
        fillcolor="#fafafa";
        color="#999999";
        fontcolor="#616161";

        pa_builder [label="System Builder\ncomposition API\nwires all crates together", fillcolor="#eeeeee", color="#999999", style="filled,dashed"];
    }

    // ══════════════════════════════════════════════════════════════
    // Edges
    // ══════════════════════════════════════════════════════════════

    // ── Trait implementations (implements arrows) ────────────────
    msgpack_store    -> event_store_trait [label="implements", style=bold,   color="#388e3c"];
    command_bus_impl -> command_bus_trait [label="implements", style=dashed, color="#999999"];
    event_bus_impl   -> event_bus_trait   [label="implements", style=dashed, color="#999999"];
    command_gw_impl  -> command_gw_trait  [label="implements", style=dashed, color="#999999"];

    // ── pit-core internal relationships ──────────────────────────
    handle_command   -> command          [label="requires\nC: Command",    color="#558b2f"];
    handle_command   -> aggregate        [label="extends\nAggregate",      color="#558b2f"];
    aggregate        -> domain_event     [label="type Event",              color="#558b2f"];
    command_bus_trait -> aggregate        [label="loads &\nreplays",        color="#558b2f"];
    command_gw_trait  -> command_bus_trait [label="wraps",                  color="#558b2f"];
    event_store_trait -> event_envelope   [label="creates\nenvelopes",     color="#558b2f"];
    event_store_trait -> aggregate_id     [label="assigns\nIDs",           color="#558b2f"];
    event_bus_trait   -> event_envelope   [label="publishes",              color="#558b2f"];
    policy           -> event_envelope   [label="reacts to",              color="#558b2f"];
    projection       -> event_envelope   [label="folds",                  color="#558b2f"];

    // ── pit-gateway internal data flow ───────────────────────────
    command_gw_impl  -> command_bus_impl [label="delegates to",    style=dashed, color="#999999"];
    command_bus_impl -> msgpack_store    [label="load / persist",  style=dashed, color="#999999"];
    command_bus_impl -> event_bus_impl   [label="publish after\npersist", style=dashed, color="#999999"];
    event_bus_impl   -> policy           [label="fan-out\nevents", style=dashed, color="#999999"];
    event_bus_impl   -> projection       [label="fan-out\nevents", style=dashed, color="#999999"];

    // ── External system connections ──────────────────────────────
    msgpack_store -> ext_fs   [label="read / write\n.msgpack",   style=bold,   color="#1565c0"];
    p_transport   -> ext_nats [label="publish /\nsubscribe",     style=dashed, color="#1565c0"];

    // ── Crate-level dependencies on pit-core (DAG from build-plan) ─
    // Uses lhead/ltail with compound=true for cluster-to-cluster edges
    pg_log       -> domain_event [label="depends on\npit-core",  style=dashed, color="#999999", lhead=cluster_pit_core];
    p_serializer -> domain_event [label="depends on\npit-core",  style=dashed, color="#999999", lhead=cluster_pit_core];
    pp_store     -> projection   [label="depends on\npit-core",  style=dashed, color="#999999", lhead=cluster_pit_core];

    // ── Cross-crate planned dependencies ─────────────────────────
    pw_http       -> command_gw_impl [label="dispatches\ncommands via", style=dashed, color="#999999"];
    pw_http       -> pp_query        [label="serves\nread models",      style=dashed, color="#999999"];
    p_serializer  -> pg_log          [label="uses file\nformat",        style=dashed, color="#999999"];
    pgd_macros    -> pg_entry        [label="derives for",              style=dashed, color="#999999"];
    p_pruning     -> pg_migration    [label="migration-time\nops",      style=dashed, color="#999999"];

    // ── pit-agent wiring ─────────────────────────────────────────
    pa_builder -> command_gw_impl [label="wires", style=dashed, color="#999999"];
    pa_builder -> msgpack_store   [label="wires", style=dashed, color="#999999"];
    pa_builder -> event_bus_impl  [label="wires", style=dashed, color="#999999"];
    pa_builder -> pp_store        [label="wires", style=dashed, color="#999999"];
    pp_store   -> projection      [label="implements\nfor",  style=dashed, color="#999999"];
}
